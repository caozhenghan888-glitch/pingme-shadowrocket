#!name=PingMe Probe
#!desc=仅用于验证 Shadowrocket 是否真的执行了 http-request 脚本

[Script]
http-request ^https:\/\/api\.pingmeapp\.net\/app\/queryBalanceAndBonus.* script-path=https://raw.githubusercontent.com/caozhenghan888-glitch/pingme-shadowrocket/main/PingMe-probe.js, requires-body=0, timeout=20, tag=PingMe Probe

[MITM]
hostname = api.pingmeapp.net
