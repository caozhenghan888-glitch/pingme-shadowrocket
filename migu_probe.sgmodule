[Script]
е’Әе’•и§Ҷйў‘жҺўй’Ҳ = type=http-request, pattern=^https?:\/\/.*\.miguvideo\.com\/.+, script-path=https://raw.githubusercontent.com/caozhenghan888-glitch/pingme-shadowrocket/main/migu_probe.js, timeout=20
е’Әе’•иҙҰеҸ·жҺўй’Ҳ = type=http-request, pattern=^https?:\/\/.*\.migu\.cn\/.+, script-path=https://raw.githubusercontent.com/caozhenghan888-glitch/pingme-shadowrocket/main/migu_probe.js, timeout=20

[MITM]
hostname = %APPEND% *.miguvideo.com, *.migu.cn
